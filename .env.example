# ============================================
# ENVIRONMENT VARIABLES - TrackAS
# ============================================

# -------- SUPABASE CONFIGURATION --------
# Supabase Project URL
VITE_SUPABASE_URL=your_supabase_project_url

# Supabase Anon Key (public key)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# -------- APPLICATION URLs --------
# Local development URL (usually http://localhost:5173)
VITE_LOCALHOST_URL=http://localhost:5173

# Vercel Deployment URL (if deployed on Vercel)
VITE_VERCEL_URL=your_vercel_app_url

# -------- FEATURE CONFIGURATION --------
# Geolocation verification radius in meters
VITE_GEOLOCATION_RADIUS=100

# Enable real-time updates
VITE_ENABLE_REAL_TIME=true

# Enable analytics dashboard
VITE_ENABLE_ANALYTICS=true

# Enable automation features
VITE_ENABLE_AUTOMATION=true

# -------- API CONFIGURATION --------
# API request timeout in milliseconds
VITE_API_TIMEOUT=30000

# -------- MONITORING & LOGGING --------
# Enable application logging
VITE_ENABLE_LOGGING=true

# Log level: debug, info, warn, error
VITE_LOG_LEVEL=info 